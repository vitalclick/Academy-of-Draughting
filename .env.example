# Public site URL — used in OG, sitemap, tracking link emails
NEXT_PUBLIC_SITE_URL=https://academydraughting.com

# Supabase — applications, documents, events, RLS
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1Ni...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...

# Resend transactional email — confirmation + admissions alerts
RESEND_API_KEY=re_...
RESEND_FROM=admissions@academydraughting.com
ADMISSIONS_INBOX=enroll@academydraughting.com

# WhatsApp Business Cloud API (Meta Graph API)
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_TOKEN=EAAJ...
WHATSAPP_TEMPLATE_NAME=application_received

# Anthropic (Claude) — powers the AIDA chatbot, recommender rationale and OCR
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_OCR_MODEL=claude-haiku-4-5-20251001

# HubSpot CRM (Private App token)
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-...

# Payfast — online enrolment deposit payments (South African gateway)
# Leave unset to run the deposit flow in mock mode (skips the gateway).
# Set PAYFAST_SANDBOX=false for live payments.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# Tracking-link JWT signing secret (>=32 random bytes recommended)
# Generate with: openssl rand -base64 48
TRACKING_TOKEN_SECRET=replace-with-a-long-random-string

# Public analytics — only loaded if cookie consent is granted
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=1234567890

# Admin allowlist — bootstrap before the admins table is populated.
# Comma-separated emails; first sign-in promotes the user to admins(role=super).
ADMIN_EMAILS=ops@academydraughting.com,coo@academydraughting.com

# Observability sink — Sentry DSN, Slack/Discord webhook, or any HTTP endpoint.
# Receives POST { level, message, timestamp, env, context }.
ERROR_SINK_URL=https://hooks.example.com/your-webhook
ERROR_SINK_TOKEN=optional-bearer-token

# Document retention window (POPIA Section 14). Default is 90 days.
DOC_RETENTION_DAYS=90

# Secret used to authenticate the Vercel Cron document-retention purge.
# Generate with: openssl rand -hex 32
# Vercel sends it as `Authorization: Bearer <CRON_SECRET>` on scheduled hits.
CRON_SECRET=replace-with-a-long-random-string
