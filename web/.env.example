# ---- Core ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- AIDA (Anthropic) ------------------------------------------------------
ANTHROPIC_API_KEY=

# ---- Supabase --------------------------------------------------------------
# Server-only (do NOT expose the service role to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public — used by browser + SSR auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Rate limiting (optional — no-op if unset) -----------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Email (optional — no-op if unset) -------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=admissions@aod.local
ADMISSIONS_NOTIFY_EMAIL=

# ---- OCR (optional — no-op if unset) ---------------------------------------
MINDEE_API_KEY=

# ---- Error reporting (optional — no-op if unset) ---------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Anti-bot on /apply (optional — no-op if unset; CAPTCHA hidden if so) -
# https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Resend webhook verification (optional; recommended for prod) ----------
# Generated in the Resend dashboard when adding the webhook.
RESEND_WEBHOOK_SECRET=

# ---- Analytics (optional, cookieless Plausible) ---------------------------
# Set to your apex domain, e.g. aod.ac.za. When unset, no script loads.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---- Antivirus (optional) --------------------------------------------------
# VirusTotal API key for hash-lookup scanning of uploads. When unset, files
# are marked scan_status='skipped' instead of scanned.
VIRUSTOTAL_API_KEY=
